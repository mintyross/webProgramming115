<!doctype html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <title>Post Published Successfully</title>
</head>
<body>
    <div class="container mt-4">
        <%- include("partials/navbar.ejs") %>

        <div class="alert alert-success my-4" role="alert">
            <h4 class="alert-heading">Success! Your post has been published.</h4>
            <p>Below is a summary of the data sent to the server.</p>
        </div>

        <div class="card mb-4">
            <div class="card-header bg-light">
                <strong>Category:</strong> <span class="badge bg-secondary text-capitalize"><%= postData.category %></span>
            </div>
            <div class="card-body">
                <h2 class="card-title"><%= postData.title %></h2>
                <hr>
                <p class="card-text" style="white-space: pre-wrap;"><%= postData.body %></p>
            </div>
        </div>

        <a href="/posts/create" class="btn btn-primary">Create Another Post</a>
        <a href="/posts" class="btn btn-outline-secondary ms-2">Go to All Posts</a>
    </div>

    <!-- JavaScript -->
    <script src="/jquery/jquery.min.js"></script>
    <script src="/bootstrap/js/bootstrap.min.js"></script>
</body>
</html>
